-- ================================
-- DOWNLOAD WORDLIST
-- ================================
local function downloadWordlist()
    local wordlist = {}
    local success = false
    
    local url = "https://raw.githubusercontent.com/geovedi/indonesian-wordlist/master/00-indonesian-wordlist.lst"
    
    print("📥 Mendownload wordlist...")
    
    local ok, content = pcall(function()
        return game:HttpGet(url)
    end)
    
    if ok and content then
        for line in string.gmatch(content, "[^\r\n]+") do
            local word = string.gsub(string.lower(line), "%s+", "")
            if #word >= 2 then
                table.insert(wordlist, word)
            end
        end
        success = #wordlist > 0
        if success then
            print("✅ Berhasil! " .. #wordlist .. " kata")
        end
    end
    
    return wordlist, success
end

