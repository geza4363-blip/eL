-- ================================
-- FUNGSI AUTO KOREKSI
-- ================================
local function clearCurrentTyping()
    pcall(function()
        BillboardUpdate:FireServer("")
    end)
end

local function getValidWord(prefix, avoidWord)
    if not prefix or prefix == "" then return nil end
    
    local prefixLower = string.lower(prefix)
    local candidates = {}
    local avoidLower = avoidWord and string.lower(avoidWord) or ""
    
    for _, word in ipairs(kataModule) do
        local w = tostring(word)
        if w and #w > 0 then
            local wLower = string.lower(w)
            if string.sub(wLower, 1, #prefixLower) == prefixLower then
                if #w >= Config.minWordLength and #w <= Config.maxWordLength then
                    if not State.usedWords[wLower] and wLower ~= avoidLower then
                        table.insert(candidates, w)
                    end
                end
            end
        end
    end
    
    if #candidates == 0 then return nil end
    
    table.sort(candidates, function(a, b)
        return #a > #b
    end)
    
    return candidates
end

-- ================================
-- AUTO ENGINE DENGAN KOREKSI (SOUND FIX)
-- ================================
local function startAutoWithCorrection()
    if State.autoRunning then return end
    if not State.autoEnabled then return end
    if not State.matchActive or not State.isMyTurn then return end
    if not State.serverLetter or State.serverLetter == "" then return end
    
    State.autoRunning = true
    
    task.spawn(function()
        local currentLetter = State.serverLetter
        local candidates = getValidWord(currentLetter)
        local selectedWord = candidates and candidates[1] or nil
        local correctionCount = 0
        local lastAttemptWord = ""
        
        while State.matchActive and State.isMyTurn and State.autoEnabled do
            if not selectedWord then
                print("❌ Tidak ada kata valid untuk: " .. currentLetter)
                State.autoRunning = false
                return
            end
            
            print("📝 Mencoba: " .. selectedWord)
            lastAttemptWord = selectedWord
            
            local currentWord = currentLetter
            local remain = selectedWord:sub(#currentLetter + 1)
            
            for i = 1, #remain do
                if not State.matchActive or not State.isMyTurn then
                    State.autoRunning = false
                    return
                end
                
                currentWord = currentWord .. remain:sub(i, i)
                
                -- MAIN SOUND (PAKAI WAITFORCHILD - PASTI ADA)
                pcall(function()
                    TypeSound:FireServer()  -- Ini harusnya work
                end)
                
                -- Update billboard
                pcall(function()
                    BillboardUpdate:FireServer(currentWord)
                end)
                
                task.wait(math.random(Config.minDelay, Config.maxDelay) / 1000)
            end
            
            task.wait(0.1)
            
            -- Submit kata
            local submitSuccess = pcall(function()
                SubmitWord:FireServer(selectedWord)
            end)
            
            if submitSuccess then
                print("✅ Submit: " .. selectedWord)
                task.wait(0.3)
                
                if State.isMyTurn then
                    print("⚠️ Kata ditolak!")
                    State.usedWords[string.lower(selectedWord)] = true
                    table.insert(State.usedWordsList, selectedWord)
                    
                    pcall(function()
                        BillboardUpdate:FireServer("")
                    end)
                    
                    task.wait(Config.correctionDelay / 1000)
                    
                    correctionCount = correctionCount + 1
                    if correctionCount >= Config.maxCorrections then
                        print("❌ Terlalu banyak koreksi")
                        break
                    end
                    
                    local newCandidates = getValidWord(currentLetter, lastAttemptWord)
                    if newCandidates and #newCandidates > 0 then
                        selectedWord = newCandidates[1]
                        print("🔄 Kata baru: " .. selectedWord)
                    else
                        print("❌ Tidak ada alternatif")
                        break
                    end
                else
                    print("✅ Kata diterima!")
                    State.usedWords[string.lower(selectedWord)] = true
                    table.insert(State.usedWordsList, selectedWord)
                    break
                end
            else
                print("❌ Submit gagal")
                break
            end
            
            task.wait(0.2)
        end
        
        pcall(function()
            BillboardEnd:FireServer()
        end)
        
        State.autoRunning = false
    end)
end

